---
layout: none
---
{
  "posts": [
    {% for post in site.posts %}
      {
        "title": {{ post.title | default: "" | jsonify }},
        "url": {{ post.url | absolute_url | jsonify }},
        "date": {{ post.date | date: '%B %d, %Y' | jsonify }},
        "excerpt": {{ post.excerpt | default: "" | strip_html | strip_newlines | truncatewords: 50 | jsonify }},
        "content": {{ post.content | default: "" | strip_html | strip_newlines | jsonify }},
        "type": "post",
        "categories": {{ post.categories | jsonify }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "thoughts": [
    {% for thought in site.thoughts %}
      {
        "title": {{ thought.title | default: "" | jsonify }},
        "url": {{ thought.url | absolute_url | jsonify }},
        "date": {{ thought.date | date: '%B %d, %Y' | jsonify }},
        "excerpt": {{ thought.description | default: thought.excerpt | default: "" | strip_html | strip_newlines | truncatewords: 50 | jsonify }},
        "content": {{ thought.content | default: "" | strip_html | strip_newlines | jsonify }},
        "type": "thought",
        "categories": {{ thought.categories | jsonify }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
} 
